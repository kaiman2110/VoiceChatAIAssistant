# Google AI Studio で発行した API キー（必須）
GEMINI_API_KEY=your-api-key-here

# VOICEVOX Engine ホスト（デフォルト: http://localhost:50021）
# VOICEVOX_HOST=http://localhost:50021

# Ollama ホスト（デフォルト: http://localhost:11434）
# OLLAMA_HOST=http://localhost:11434

# Whisper モデルサイズ（デフォルト: large-v3）
# WHISPER_MODEL=large-v3

# カスタム Wake Word モデルのパス（.tflite/.onnx）
# WAKEWORD_MODEL=models/wakeword/custom_model.onnx

# 保持する会話履歴の最大往復数（デフォルト: 10）
# MAX_CHAT_HISTORY=10

# VOICEVOX デフォルトキャラ ID（デフォルト: 3 = ずんだもん）
# DEFAULT_SPEAKER_ID=3
